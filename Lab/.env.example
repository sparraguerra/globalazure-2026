# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://openaioib5c7bnlbyc4.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_TTS_API_VERSION=2024-12-01-preview

# Evaluator execution mode: "local" (current behavior) or "foundry-agent"
# EVALUATOR_EXECUTION_MODE=foundry-agent
EVALUATOR_EXECUTION_MODE=local

# Used only when EVALUATOR_EXECUTION_MODE=foundry-agent
# Full Responses API endpoint from your published Foundry agent application
FOUNDRY_EVALUATOR_RESPONSES_ENDPOINT=https://gas-2026-foundry.services.ai.azure.com/api/projects/gas-2026-project/applications/eval-agent/protocols/openai/responses?api-version=2025-11-15-preview
# Optional reference only (not used by current toggle implementation):
# FOUNDRY_EVALUATOR_ACTIVITY_ENDPOINT=https://gas-2026-foundry.services.ai.azure.com/api/projects/gas-2026-project/applications/eval-agent/protocols/activityprotocol?api-version=2025-11-15-preview
# Optional model override for Responses payload
FOUNDRY_EVALUATOR_MODEL=
# Auth options (set one): API key or bearer token or rely on DefaultAzureCredential
FOUNDRY_EVALUATOR_API_KEY=
FOUNDRY_EVALUATOR_BEARER_TOKEN=
# Scope used by DefaultAzureCredential when no key/token is provided
FOUNDRY_EVALUATOR_SCOPE=https://ai.azure.com/.default

# GitHub (optional, increases API rate limits)
GITHUB_TOKEN=

# Content Factory Mode: "lab" (Azure OpenAI TTS) or "full" (GPU XTTS-v2)
CONTENT_FACTORY_MODE=full

# Agent 3 - Podcaster
TTS_SERVER_URL=http://localhost:8004
TTS_HOST_VOICE=host-female
TTS_GUEST_VOICE=guest-male
TTS_TIMEOUT_BUDGET_SECONDS=300
AZURE_STORAGE_CONNECTION_STRING=
